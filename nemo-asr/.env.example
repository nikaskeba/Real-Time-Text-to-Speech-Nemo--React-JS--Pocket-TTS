# Copy this file to .env before running the ASR web gateway.
#
# Required when the ASR web gateway calls an authenticated LLM/TTS/ASR gateway.
# Use either the raw token or Bearer-prefixed form:
# ASR_AUTHORIZATION=123::your-api-key
# ASR_AUTHORIZATION=Bearer 123::your-api-key
ASR_AUTHORIZATION=

# Optional browser Basic Auth for the React app.
# Leave FRONTEND_AUTH_PASSWORD blank to disable the browser login prompt.
FRONTEND_AUTH_USER=admin
FRONTEND_AUTH_PASSWORD=
FRONTEND_AUTH_REALM=ASR

# Optional service-specific overrides.
LLM_AUTHORIZATION=
TTS_AUTHORIZATION=
