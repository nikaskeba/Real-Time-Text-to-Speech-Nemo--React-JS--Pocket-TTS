ASR_WS_ENDPOINT=wss://asr.skeba.info/ws
ASR_API_BASE_URL=https://asr.skeba.info
TTS_API_BASE_URL=https://tts.skeba.info
TTS_SYNTHESIZE_URL=https://tts.skeba.info/api/synthesize
TTS_SYNTHESIZE_STREAM_URL=https://tts.skeba.info/api/synthesize/stream
TTS_VOICE_CLONE_URL=https://tts.skeba.info/api/voices/clone
LLM_API_BASE_URL=https://ollama.skeba.info
LLM_MODELS_URL=https://ollama.skeba.info/v1/models
LLM_CHAT_COMPLETIONS_URL=https://ollama.skeba.info/v1/chat/completions
LLM_MODEL=gemma-3-4b-it
VITE_LLM_MAX_TOKENS=96
VITE_LLM_CONTEXT_WINDOW=2048
# Optional. Falls back to ASR_AUTHORIZATION when omitted.
LLM_AUTHORIZATION=Bearer 123::your-api-key
ASR_AUTHORIZATION=Bearer 123::your-api-key
PROXY_PORT=8787
# Leave blank in production to use same-origin /ws and window.location.origin.
VITE_PROXY_WS_URL=
VITE_PROXY_HTTP_URL=
